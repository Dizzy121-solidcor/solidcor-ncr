// ── Main handler ──────────────────────────────────────────────────
exports.handler = async (event) => {
  // CORS headers so the browser can call this
  const headers = {
    'Access-Control-Allow-Origin': '*',
    'Access-Control-Allow-Headers': 'Content-Type',
    'Content-Type': 'application/json'
  };

  if (event.httpMethod === 'OPTIONS') {
    return { statusCode: 200, headers, body: '' };
  }
  if (event.httpMethod !== 'POST') {
    return { statusCode: 405, headers, body: JSON.stringify({ error: 'Method not allowed' }) };
  }

  let body;
  try { body = JSON.parse(event.body); }
  catch { return { statusCode: 400, headers, body: JSON.stringify({ error: 'Invalid JSON' }) }; }

  const { type, ncr, resolution, component, qty, notify_email, picker_email, customer_email } = body;

  const results = [];

  try {
    switch (type) {

      case 'submission': {
        // Customer confirmation + NCR alert
        if (customer_email || ncr.customer_email) {
          const to = customer_email || ncr.customer_email;
          const r = await sendViaEmailJS(to,
            `[Solidcor] NCR Received — ${ncr.id} — ${ncr.door_ref || ncr.customer}`,
            buildSubmissionEmail(ncr));
          results.push({ to, ok: r.ok });
        }
        if (notify_email) {
          const typeLabel = ncr.type === 'external' ? 'External' : 'Internal';
          const r = await sendViaEmailJS(notify_email,
            `[NCR Alert] ${typeLabel} — ${ncr.id} — ${ncr.customer || ncr.raised_by}`,
            buildAlertEmail(ncr));
          results.push({ to: notify_email, ok: r.ok });
        }
        break;
      }

      case 'resolution': {
        if (customer_email || ncr.customer_email) {
          const to = customer_email || ncr.customer_email;
          const r = await sendViaEmailJS(to,
            `[Solidcor] NCR Resolved — ${ncr.id}`,
            buildResolutionEmail(ncr, resolution));
          results.push({ to, ok: r.ok });
        }
        break;
      }

      case 'alert': {
        if (notify_email) {
          const typeLabel = ncr.type === 'external' ? 'External' : 'Internal';
          const r = await sendViaEmailJS(notify_email,
            `[NCR Alert] ${typeLabel} — ${ncr.id} — ${ncr.customer || ncr.raised_by}`,
            buildAlertEmail(ncr));
          results.push({ to: notify_email, ok: r.ok });
        }
        break;
      }

      case 'picker': {
        if (picker_email) {
          const r = await sendViaEmailJS(picker_email,
            `[Solidcor] Pick required — ${component} for NCR ${ncr.id}`,
            buildPickerEmail(ncr.id, component, qty));
          results.push({ to: picker_email, ok: r.ok });
        }
        break;
      }

      default:
        return { statusCode: 400, headers, body: JSON.stringify({ error: 'Unknown type: ' + type }) };
    }

    return {
      statusCode: 200,
      headers,
      body: JSON.stringify({ ok: true, results })
    };

  } catch (e) {
    console.error('send-ncr-email error:', e.message);
    return { statusCode: 500, headers, body: JSON.stringify({ error: e.message }) };
  }
};
