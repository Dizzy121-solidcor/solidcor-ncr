const https = require('https');

const EJS_SERVICE  = process.env.EJS_SERVICE_ID;
const EJS_TEMPLATE = process.env.EJS_TEMPLATE_ID;
const EJS_PUBKEY   = process.env.EJS_PUBLIC_KEY;
const NETLIFY_URL  = process.env.URL || 'https://delightful-beijinho-67f487.netlify.app';

// Send via EmailJS REST API
function sendViaEmailJS(toEmail, subject, htmlBody) {
  return new Promise((resolve) => {
    if (!EJS_SERVICE || !EJS_TEMPLATE || !EJS_PUBKEY) {
      console.log('EmailJS not configured');
      resolve({ ok: false, reason: 'EmailJS env vars not set' });
      return;
    }

    const payload = JSON.stringify({
      service_id:   EJS_SERVICE,
      template_id:  EJS_TEMPLATE,
      user_id:      EJS_PUBKEY,
      template_params: {
        to_email:  toEmail,
        subject:   subject,
        html_body: htmlBody,
        reply_to:  'quality@solidcor.co.uk'
      }
    });

    const req = https.request({
      hostname: 'api.emailjs.com',
      path:     '/api/v1.0/email/send',
      method:   'POST',
      headers: {
        'Content-Type':   'application/json',
        'Content-Length': Buffer.byteLength(payload),
        'origin':         NETLIFY_URL
      }
    }, (res) => {
      let data = '';
      res.on('data', c => data += c);
      res.on('end', () => {
        console.log(`Email to ${toEmail}: HTTP ${res.statusCode} — ${data.slice(0, 100)}`);
        resolve({ ok: res.statusCode === 200, status: res.statusCode, body: data });
      });
    });
    req.on('error', e => resolve({ ok: false, reason: e.message }));
    req.write(payload);
    req.end();
  });
}

